{
  "buildCommand": "npm install && npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/task-reminders",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/daily-briefing-cron",
      "schedule": "*/30 10-23 * * *"
    },
    {
      "path": "/api/report-cron",
      "schedule": "0 * * * *"
    }
  ]
}